<?xml version="1.0"?>
<!-- Floor zone — thin flat box marking the sweeping area -->
<robot name="floor_zone">

  <link name="zone">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <!-- 2m × 2m zone, 2cm thick -->
        <box size="2.0 2.0 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="dirt">
        <color rgba="0.65 0.45 0.20 0.7"/>
      </material>
    </visual>
    <!-- No collision — drones can fly through it -->
  </link>

</robot>
